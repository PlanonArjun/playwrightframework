  "scripts": {
    "test:globalfooter:appandsociallinks:ios": "npx browserstack-node-sdk playwright test --workers=5 -g d2c.marketplace/globalfooter_appandsociallinks.spec.ts --browserstack.config=./browserstack.ios.yml --config=./playwright.ios.config.ts",
    "test:globalfooter:appandsociallinks:desktop": "npx browserstack-node-sdk playwright test --workers=5 -g d2c.marketplace/globalfooter_appandsociallinks.spec.ts --browserstack.config=./browserstack.desktop.yml --config=./playwright.config.ts",
    "test:globalfooter:appandsociallinks:android": "npx browserstack-node-sdk playwright test --workers=5 -g d2c.marketplace/globalfooter_appandsociallinks.spec.ts --browserstack.config=./browserstack.android.yml --config=./playwright.config.ts",
    "test:customerjourney1:leaseonline:desktop": "npx browserstack-node-sdk playwright test --workers=5 -g d2c.marketplace/customerjourney1_leaseonline.spec.ts --browserstack.config=./browserstack.desktop.yml --config=./playwright.config.ts",
    "test:customerjourney2:estimatecost:desktop": "npx browserstack-node-sdk playwright test --workers=5 -g d2c.marketplace/customerjourney1_leaseonline.spec.ts --browserstack.config=./browserstack.desktop.yml --config=./playwright.config.ts"
     },
